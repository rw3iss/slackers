{
  "laugh": "$sender laughs.",
  "lol": "$sender laughs out loud.",
  "cry": "$sender cries.",
  "wave": "$sender waves at $receiver.",
  "hug": "$sender hugs $receiver.",
  "shrug": "$sender shrugs.",
  "dance": "$sender dances.",
  "facepalm": "$sender facepalms.",
  "highfive": "$sender high-fives $receiver!",
  "poke": "$sender pokes $receiver.",
  "slap": "$sender slaps $receiver with a large trout.",
  "nod": "$sender nods.",
  "bow": "$sender bows.",
  "flex": "$sender flexes.",
  "cheer": "$sender cheers!",
  "sigh": "$sender sighs.",
  "yawn": "$sender yawns.",
  "wink": "$sender winks at $receiver.",
  "salute": "$sender salutes $receiver.",
  "panic": "$sender panics!",
  "think": "$sender thinks...",
  "clap": "$sender claps.",
  "fist": "$sender fist-bumps $receiver.",
  "eye": "$sender eyes $receiver suspiciously.",
  "emote": "$sender $text"
}
